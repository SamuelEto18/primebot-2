# PrimeBot 2 Telegram control bot and Telethon credentials
BOT_TOKEN=
ADMIN_ID=
API_ID=
API_HASH=
SESSION_NAME=primebot2

# Fixed PrimeBot 2 source. Startup fails if this differs from config.py.
CHANNEL_ID=-1002792547449

# Existing PrimeBot 2 MT5 login. Sticker management fails closed if omitted or
# if the currently connected terminal account does not match.
MT5_LOGIN=

# Exact Telegram sticker document IDs, separated by commas. Leave empty until
# the IDs have been captured from the configured source channel.
TELEGRAM_STICKER_BREAK_EVEN_DOCUMENT_IDS=
TELEGRAM_STICKER_CLOSE_ALL_DOCUMENT_IDS=

# Optional: also send sticker discovery metadata to the control bot.
TELEGRAM_STICKER_DISCOVERY_NOTIFY=false
